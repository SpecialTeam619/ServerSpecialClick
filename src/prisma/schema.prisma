datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    output   = "./generated"
}

model UserModel {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now())
    email     String   @unique
    name      String?
    role      Role     @default(CUSTOMER)
}

enum Role {
    CUSTOMER
    LESSOR
}
