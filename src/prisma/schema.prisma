datasource db {
  provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    output   = "./generated"
}

model UserModel {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now())
    email     String   @unique
    name      String?
    role      Role     @default(CUSTOMER)
    password  String
    posts     PostModel[]
}

model PostModel {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now())
    authorId  Int
    author    UserModel @relation(fields: [authorId], references: [id])
    title     String
    description String
    price     Float
    properties String[]
}


enum Role {
    CUSTOMER
    LESSOR
}
